<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.skillcheck.mapper.QuestionMapper">

    <!-- 全件取得 -->
    <select id="findAll" resultType="com.example.skillcheck.entity.Question">
        SELECT
            id,
            question,
            choice1,
            choice2,
            choice3,
            choice4,
            answer
        FROM questions
    </select>

</mapper>